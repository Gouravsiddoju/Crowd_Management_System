stream: {type: file, file_path: cr.mp4, rtsp_url: '', rtsp_reconnect_attempts: 5,
  rtsp_reconnect_delay: 5, rtsp_buffer_size: 30, rtsp_transport: tcp, webcam_id: 0,
  directory_path: '', directory_pattern: '*.mp4'}
output:
  display_preview: true
  preview_width: 1280
  preview_height: 720
  save_video: false
  video_path: output_counted.mp4
  video_codec: mp4v
  save_frames: false
  frames_path: output_frames/
  frames_interval: 30
  show_boxes: true
  show_track_ids: true
  show_trajectories: false
  show_heatmap: false
  box_color: [0, 255, 0]
  box_thickness: 2
  text_size: 0.6
  text_color: [0, 255, 255]
analytics: {enabled: true, log_to_console: true, log_to_file: true, log_file: analytics.csv,
  log_interval: 1, track_occupancy: true, track_peak_occupancy: true, track_flow_rate: true,
  track_dwell_time: true, track_fps: true, alerts_enabled: false, alert_threshold: 100,
  alert_sound: false, alert_webhook: ''}
calibration: {enabled: false, camera_height_meters: 4.0, camera_angle_degrees: 45,
  fov_horizontal_degrees: 90, reference_person_height_pixels: 200, reference_person_height_meters: 1.7}
advanced: {debug_mode: false, save_debug_images: false, profile_performance: false,
  verbose_logging: false}
