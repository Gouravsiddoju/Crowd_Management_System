model: {name: /media/gouravsiddoju/Data/PROJECTS/Head_Counter/best.pt, imgsz: 1024, conf_threshold: 0.15, iou_threshold: 0.45, device: 0,
  half_precision: true}
tracking: {tracker: botsort.yaml, reid_enabled: true, reid_threshold: 0.6, reid_interval: 5,
  max_age: 120, min_hits: 3}
filtering: {min_person_height: 10, min_person_width: 10, min_aspect_ratio: 0.5, max_aspect_ratio: 5.0,
  size_adaptation: true}
# Physical Parameters (Capacity Calculation)
physical_params:
  # Area occupied by a person (standing w/ luggage).
  # Increased to 1.2 to better reflect "Perceived Crowdedness"
  base_footprint_m2: 1.2
  
  # Buffer factors (Social distancing / Comfort)
  buffer_factor_low: 1.5   # Crowded
  buffer_factor_high: 2.5  # Comfortable
performance: {mode: ACCURATE, frame_skip: 3, multi_threading: true, gpu_batch_size: 1,
  max_fps: 30}
performance_modes:
  FAST: {model_name: yolov8m.pt, imgsz: 640, frame_skip: 3, conf_threshold: 0.4}
  BALANCED: {model_name: yolov8x.pt, imgsz: 960, frame_skip: 2, conf_threshold: 0.25}
  ACCURATE: {model_name: yolov8x.pt, imgsz: 1280, frame_skip: 1, conf_threshold: 0.2}
preprocessing: {enabled: true, resize_width: 1280, grayscale: false, roi: null, lighting_normalization: true,
  motion_blur_handling: false, denoising: true, auto_white_balance: true, stabilization: false}
counting:
  mode: both
  smooth_window: 30
  save_unique_ids: true
  zones_enabled: false
  zones: []
